#!/usr/bin/env bash
# Temporarily lift network restrictions on a sandbox and open a shell or run a
# command. This is helpful for setup and installing dependencies.

set -uo pipefail

sandbox="${1:?usage: $0 SANDBOX}"
shift

before="$(sbx policy ls "$sandbox")"

cleanup() {
  sbx policy rm network "$sandbox" --resource '**' || true
  local after
  after="$(sbx policy ls "$sandbox")"
  echo "--- policy diff for $sandbox ---"
  if diff -U 1000000 <(echo "$before") <(echo "$after"); then
    # diff prints nothing when there are no changes
    printf '%s\n' "$after"
    echo "policy unchanged"
  else
    echo "policy changed!"
    exit 1
  fi
}
trap cleanup EXIT

sbx policy allow network "$sandbox" '**'
sbx exec -it "$sandbox" "${@:-bash}"
